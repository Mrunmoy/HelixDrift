CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# ── Flash size ───────────────────────────────────────────────────────────────
# ESP32-WROOM-32 module used here has 4 MB flash.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# ── Partition table ──────────────────────────────────────────────────────────
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_ota.csv"

# ── OTA rollback ─────────────────────────────────────────────────────────────
# If app never calls esp_ota_mark_app_valid_cancel_rollback(), the bootloader
# reverts to the previous image on the next reset.
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# ── Bluetooth (NimBLE) ───────────────────────────────────────────────────────
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=n
CONFIG_BT_NIMBLE_HOST_TASK_STACK_SIZE=4096
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1

# ── I2C ──────────────────────────────────────────────────────────────────────
# Suppress deprecation warning — we use the new esp_driver_i2c, not driver/i2c.h
CONFIG_I2C_SUPPRESS_DEPRECATE_WARN=y
