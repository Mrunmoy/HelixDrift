mainmenu "Helix nRF52840 Mocap Bridge"

source "Kconfig.zephyr"

menu "Helix Mocap Bridge"

choice HELIX_MOCAP_BRIDGE_ROLE
	prompt "Bridge role"
	default HELIX_MOCAP_BRIDGE_ROLE_CENTRAL

config HELIX_MOCAP_BRIDGE_ROLE_CENTRAL
	bool "Central / PRX"

config HELIX_MOCAP_BRIDGE_ROLE_NODE
	bool "Synthetic node / PTX"

endchoice

config HELIX_MOCAP_NODE_ID
	int "Node ID"
	range 1 255
	default 1

config HELIX_MOCAP_CENTRAL_ID
	int "Central ID"
	range 0 255
	default 0

config HELIX_MOCAP_PIPE
	int "ESB pipe"
	range 0 7
	default 0

config HELIX_MOCAP_RF_CHANNEL
	int "ESB RF channel"
	range 0 100
	default 40

config HELIX_MOCAP_SEND_PERIOD_MS
	int "Node send period in milliseconds"
	range 5 5000
	default 20

config HELIX_MOCAP_SESSION_TAG
	int "Session tag"
	range 0 255
	default 77

config HELIX_MOCAP_MAX_TRACKED_NODES
	int "Maximum tracked nodes at the central"
	range 1 16
	default 10

config HELIX_MOCAP_USB_WAIT_FOR_DTR_MS
	int "How long the central waits for host DTR before continuing"
	range 0 30000
	default 5000

config HELIX_MOCAP_USB_VID
	hex "USB vendor ID"
	range 0x0001 0xFFFF
	default 0x1915

config HELIX_MOCAP_USB_PID
	hex "USB product ID"
	range 0x0001 0xFFFF
	default 0x1040 if HELIX_MOCAP_BRIDGE_ROLE_CENTRAL
	default 0x1041 if HELIX_MOCAP_BRIDGE_ROLE_NODE

config HELIX_MOCAP_NODE_LED_DEBUG
	bool "Encode node RF state in LED cadence"
	default y if HELIX_MOCAP_BRIDGE_ROLE_NODE
	help
	  When enabled on node builds, the LED cadence indicates node state:
	  fast blink means the node is alive but has not yet confirmed TX success,
	  medium blink means TX is succeeding without sync anchors, and slow blink
	  means sync anchors are being received from the central.

config HELIX_OTA_HUB_RELAY
	bool "Enable OTA relay from Hub to Tags over BLE"
	default y if HELIX_MOCAP_BRIDGE_ROLE_CENTRAL && BT
	help
	  When enabled, the Hub can relay OTA firmware updates from the PC
	  to Tags over BLE. The PC sends UartOtaProtocol frames over USB CDC,
	  the Hub forwards them to a Tag's BLE GATT OTA service.

config HELIX_OTA_BOOT_WINDOW_MS
	int "BLE OTA boot window in milliseconds (0 to skip)"
	range 0 60000
	default 30000 if HELIX_MOCAP_BRIDGE_ROLE_NODE
	default 0
	help
	  Duration of the BLE OTA advertising window at boot. If a BLE
	  connection is made during this window, OTA proceeds. If not,
	  the device transitions to ESB mocap mode. Set to 0 to skip
	  the BLE window entirely and boot straight into ESB.

config HELIX_OTA_TARGET_ID
	hex "OTA target identity"
	default 0x52840071

config HELIX_BOOTLOADER_VERSION_MAJOR
	int "Bootloader (MCUboot) major version — manually bumped"
	default 1
	help
	  MCUboot does not publish its own version to the app, so we track
	  it manually here. Bump whenever MCUboot itself is rebuilt.

config HELIX_BOOTLOADER_VERSION_MINOR
	int "Bootloader (MCUboot) minor version"
	default 0

config HELIX_BOOTLOADER_VERSION_REVISION
	int "Bootloader (MCUboot) revision"
	default 0

config HELIX_OTA_REBOOT_DELAY_MS
	int "Reboot delay after OTA commit (ms)"
	default 300

endmenu
