# Time Sync §8 - End-to-End Latency Budget

direction: right

s1: Sensor sample ~1 ms {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.font-size: 11
}

s2: Fusion (AHRS) ~0.5 ms {
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  style.font-size: 11
}

s3: Pack frame ~0.1 ms {
  shape: rectangle
  style.fill: "#A5D6A7"
  style.stroke: "#1B5E20"
  style.font-size: 11
}

s4: ESB TX + ACK ~1 ms {
  shape: rectangle
  style.fill: "#BBDEFB"
  style.stroke: "#1565C0"
  style.font-size: 11
}

s5: Hub decode ~0.1 ms {
  shape: rectangle
  style.fill: "#90CAF9"
  style.stroke: "#0D47A1"
  style.font-size: 11
}

s6: USB write ~1 ms {
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.font-size: 11
}

s7: PC parse ~0.5 ms {
  shape: rectangle
  style.fill: "#e0e0e0"
  style.stroke: "#999"
  style.font-size: 11
}

s1 -> s2
s2 -> s3
s3 -> s4
s4 -> s5
s5 -> s6
s6 -> s7
