# URL list for automated fetch attempts.
# If a URL is not a direct PDF, the fetch script will skip it.

NRF52840_PS_URL=https://infocenter.nordicsemi.com/pdf/nRF52840_PS_v1.9.pdf
NRF52840_ERRATA_URL=https://infocenter.nordicsemi.com/pdf/nRF52840_Errata_v1.9.pdf

# ARM links are often HTML docs, not direct PDFs.
ARM_CORTEX_M4_TRM_URL=https://developer.arm.com/documentation/ddi0439/latest
ARMV7M_ARM_URL=https://developer.arm.com/documentation/ddi0403/latest

# Sensor links are vendor landing pages by default.
LSM6DSO_DS_URL=https://www.st.com/en/mems-and-sensors/lsm6dso.html
BMM350_DS_URL=https://www.bosch-sensortec.com/products/motion-sensors/magnetometers/bmm350/
LPS22DF_DS_URL=https://www.st.com/en/mems-and-sensors/lps22df.html
